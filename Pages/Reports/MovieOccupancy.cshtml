@page "/reports/movie-occupancy"
@model KumariCinemas.Web.Pages.Reports.MovieOccupancyModel
@{
    ViewData["Title"] = "Movie Occupancy Report";
}

<div class="kc-page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between py-4 flex-wrap gap-3">
            <div>
                <h1 class="kc-dashboard-title mb-1">
                    <i class="fa-solid fa-chart-pie me-2 kc-gold"></i>Movie Theater Occupancy Report
                </h1>
                <p class="text-secondary mb-0 small">
                    Select a movie to view the <strong>top 3 theatres</strong> with maximum seat occupancy based on <strong>paid tickets</strong>.
                </p>
            </div>
            <a href="/reports" class="btn kc-btn-outline btn-sm">
                <i class="fa-solid fa-arrow-left me-1"></i>Back to Reports
            </a>
        </div>
    </div>
</div>

@* ── Search Form ──────────────────────────────────────────── *@
<section class="kc-section kc-section-dark" style="padding: 1.5rem 0;">
    <div class="container">
        <form method="post" class="row g-3 align-items-end">
            <div class="col-md-6 col-lg-4">
                <label class="form-label">Select Movie</label>
                <select class="form-select kc-input" name="SelectedMovieId" required>
                    <option value="">-- Choose a Movie --</option>
                    @foreach (var m in Model.MovieOptions)
                    {
                        <option value="@m.Value" selected="@(m.Value == Model.SelectedMovieId?.ToString())">@m.Text</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn kc-btn-primary">
                    <i class="fa-solid fa-magnifying-glass me-1"></i>Generate Report
                </button>
            </div>
        </form>
    </div>
</section>

@if (TempData["Info"] != null)
{
    <div class="container mt-3">
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="fa-solid fa-circle-info me-1"></i>@TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

@* ── Report Output ────────────────────────────────────────── *@
@if (Model.Report != null)
{
    var rpt = Model.Report;

    @* ── MOVIE DETAILS CARD ── *@
    <section class="kc-section kc-section-mid" style="padding: 1.5rem 0;">
        <div class="container">
            <div class="kc-card p-4">
                <h5 class="kc-gold mb-3"><i class="fa-solid fa-film me-2"></i>Movie Details</h5>
                <div class="row g-3">
                    <div class="col-md-3">
                        <span class="text-secondary small d-block">Title</span>
                        <strong class="text-white">@rpt.MovieTitle</strong>
                    </div>
                    <div class="col-md-3">
                        <span class="text-secondary small d-block">Genre</span>
                        <span class="text-white">@(string.IsNullOrEmpty(rpt.Genre) ? "—" : rpt.Genre)</span>
                    </div>
                    <div class="col-md-3">
                        <span class="text-secondary small d-block">Language</span>
                        <span class="text-white">@(string.IsNullOrEmpty(rpt.Language) ? "—" : rpt.Language)</span>
                    </div>
                    <div class="col-md-3">
                        <span class="text-secondary small d-block">Duration</span>
                        <span class="text-white">@rpt.Duration min</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ── SUMMARY STATS ── *@
    <section class="kc-section kc-section-dark py-3">
        <div class="container">
            <div class="row g-3">
                <div class="col-6 col-md-4">
                    <div class="kc-stat-card">
                        <div class="kc-stat-icon kc-icon-gold"><i class="fa-solid fa-ticket"></i></div>
                        <div class="kc-stat-body">
                            <span class="kc-stat-value">@rpt.TotalPaidTickets</span>
                            <span class="kc-stat-label">Total Paid Tickets</span>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="kc-stat-card">
                        <div class="kc-stat-icon kc-icon-green"><i class="fa-solid fa-building"></i></div>
                        <div class="kc-stat-body">
                            <span class="kc-stat-value">@rpt.TopTheatres.Count</span>
                            <span class="kc-stat-label">Theatres (Top 3)</span>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4">
                    <div class="kc-stat-card">
                        <div class="kc-stat-icon kc-icon-blue"><i class="fa-solid fa-percent"></i></div>
                        <div class="kc-stat-body">
                            <span class="kc-stat-value">@(rpt.TopTheatres.Any() ? rpt.TopTheatres.First().OccupancyPercent.ToString("N1") + "%" : "—")</span>
                            <span class="kc-stat-label">Highest Occupancy</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* ── TOP 3 THEATRES TABLE ── *@
    <section class="kc-section kc-section-dark" style="padding: 1rem 0 3rem;">
        <div class="container">
            <h5 class="kc-gold mb-3">
                <i class="fa-solid fa-trophy me-2"></i>Top 3 TheaterCityHall by Seat Occupancy (Paid Tickets Only)
            </h5>

            @if (rpt.TopTheatres.Any())
            {
                <div class="row g-4 mb-4">
                    @foreach (var th in rpt.TopTheatres)
                    {
                        var medalIcon = th.Rank switch
                        {
                            1 => "fa-solid fa-medal",
                            2 => "fa-solid fa-award",
                            _ => "fa-solid fa-certificate"
                        };
                        var medalColor = th.Rank switch
                        {
                            1 => "#ffd700",
                            2 => "#c0c0c0",
                            _ => "#cd7f32"
                        };
                        var occClass = th.OccupancyPercent >= 80 ? "kc-status-filling" :
                                       th.OccupancyPercent >= 50 ? "kc-status-open" : "kc-status-cancelled";
                        <div class="col-md-4">
                            <div class="kc-card p-4 h-100" style="border:1px solid rgba(209,165,48,.25);">
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <i class="@medalIcon fa-2x" style="color:@medalColor;"></i>
                                    <div>
                                        <h6 class="kc-gold mb-0">#@th.Rank @th.TheatreName</h6>
                                        <span class="text-secondary small">@th.TheatreCity</span>
                                    </div>
                                </div>
                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <span class="text-secondary small d-block">Hall</span>
                                        <span class="text-white small fw-bold">@th.HallName</span>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-secondary small d-block">Capacity</span>
                                        <span class="text-white small">@th.HallCapacity seats</span>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-secondary small d-block">Shows</span>
                                        <span class="text-white small">@th.TotalShows</span>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-secondary small d-block">Total Seats</span>
                                        <span class="text-white small">@th.TotalSeats</span>
                                    </div>
                                    <div class="col-6">
                                        <span class="text-secondary small d-block">Paid Tickets</span>
                                        <span class="text-white small fw-bold">@th.PaidTickets</span>
                                    </div>
                                </div>
                                <div class="mt-auto">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <span class="text-secondary small">Occupancy</span>
                                        <span class="kc-status-badge @occClass">@th.OccupancyPercent.ToString("N1")%</span>
                                    </div>
                                    <div class="progress" style="height:8px; background:rgba(255,255,255,0.08); border-radius:4px;">
                                        <div class="progress-bar" style="width:@th.OccupancyPercent%; background:var(--kc-gold); border-radius:4px;"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* Full detail table *@
                <div class="table-responsive">
                    <table class="table kc-table">
                        <thead>
                            <tr>
                                <th>Rank</th>
                                <th>Theatre</th>
                                <th>City</th>
                                <th>Hall</th>
                                <th>Capacity</th>
                                <th>Shows</th>
                                <th>Total Seats</th>
                                <th>Paid Tickets</th>
                                <th>Occupancy %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var th in rpt.TopTheatres)
                            {
                                var occClass = th.OccupancyPercent >= 80 ? "kc-status-filling" :
                                               th.OccupancyPercent >= 50 ? "kc-status-open" : "kc-status-cancelled";
                                <tr>
                                    <td class="kc-gold fw-bold">@th.Rank</td>
                                    <td><strong class="text-white">@th.TheatreName</strong></td>
                                    <td>@th.TheatreCity</td>
                                    <td>@th.HallName</td>
                                    <td>@th.HallCapacity</td>
                                    <td>@th.TotalShows</td>
                                    <td>@th.TotalSeats</td>
                                    <td class="fw-bold">@th.PaidTickets</td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress" style="height:6px; width:60px; background:rgba(255,255,255,0.08); border-radius:3px;">
                                                <div class="progress-bar" style="width:@th.OccupancyPercent%; background:var(--kc-gold); border-radius:3px;"></div>
                                            </div>
                                            <span class="kc-status-badge @occClass">@th.OccupancyPercent.ToString("N1")%</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-4">
                    <i class="fa-solid fa-chart-pie fa-3x mb-3 d-block" style="opacity:.3;"></i>
                    <p>No theatre/hall data with paid tickets found for this movie.</p>
                </div>
            }

            @* ── SQL QUERY REFERENCE ── *@
            <details class="mt-4">
                <summary class="kc-gold" style="cursor:pointer;">
                    <i class="fa-solid fa-database me-1"></i>View SQL Query Used
                </summary>
                <pre class="mt-2 p-3"
                     style="background:#1a1a2e; border:1px solid #333; border-radius:8px; color:#d1a530; font-size:.8rem; overflow-x:auto;">
SELECT th.TheatreID, th.TheatreName, th.TheatreCity,
       h.HallName, h.HallCapacity,
       COUNT(DISTINCT s.ShowID) AS TotalShows,
       COUNT(DISTINCT s.ShowID) * h.HallCapacity AS TotalSeats,
       COUNT(t.TicketID) AS PaidTickets,
       ROUND(COUNT(t.TicketID) * 100.0
             / NULLIF(COUNT(DISTINCT s.ShowID) * h.HallCapacity, 0), 2)
             AS OccupancyPct
FROM   Show s
       JOIN Hall h     ON s.HallID    = h.HallID
       JOIN Theatre th ON h.TheatreID = th.TheatreID
       LEFT JOIN Booking b ON b.ShowID = s.ShowID
       LEFT JOIN Ticket t  ON t.BookingID = b.BookingID
                           AND t.TicketStatus = 'Paid'
WHERE  s.MovieID = :movieId
GROUP BY th.TheatreID, th.TheatreName, th.TheatreCity,
         h.HallName, h.HallCapacity
ORDER BY OccupancyPct DESC
FETCH FIRST 3 ROWS ONLY</pre>
            </details>
        </div>
    </section>
}
