@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

@* DASHBOARD HEADER *@
<section class="kc-dashboard-hero">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 py-4">
            <div>
                <h1 class="kc-dashboard-title mb-1">
                    <i class="fa-solid fa-gauge-high me-2 kc-gold"></i>Operations Dashboard
                </h1>
                <p class="text-secondary mb-0">Overview of cinema operations for Kumari Cinemas.</p>
            </div>
            <span class="kc-section-badge">
                <i class="fa-regular fa-calendar me-1"></i>@DateTime.Now.ToString("dddd, MMMM d, yyyy")
            </span>
        </div>
    </div>
</section>

@* STATS OVERVIEW *@
<section class="kc-section kc-section-dark py-4">
    <div class="container">
        <div class="row g-4">
            <div class="col-6 col-lg-3">
                <div class="kc-stat-card">
                    <div class="kc-stat-icon kc-icon-blue"><i class="fa-solid fa-film"></i></div>
                    <div class="kc-stat-body">
                        <span class="kc-stat-value">@Model.Movies</span>
                        <span class="kc-stat-label">Movies Active</span>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="kc-stat-card">
                    <div class="kc-stat-icon kc-icon-gold"><i class="fa-solid fa-clapperboard"></i></div>
                    <div class="kc-stat-body">
                        <span class="kc-stat-value">@Model.ShowsToday</span>
                        <span class="kc-stat-label">Shows Today</span>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="kc-stat-card">
                    <div class="kc-stat-icon kc-icon-green"><i class="fa-solid fa-building"></i></div>
                    <div class="kc-stat-body">
                        <span class="kc-stat-value">@Model.Halls</span>
                        <span class="kc-stat-label">Halls</span>
                    </div>
                </div>
            </div>
            <div class="col-6 col-lg-3">
                <div class="kc-stat-card">
                    <div class="kc-stat-icon kc-icon-red"><i class="fa-solid fa-ticket"></i></div>
                    <div class="kc-stat-body">
                        <span class="kc-stat-value">@Model.TicketsSoldToday</span>
                        <span class="kc-stat-label">Tickets Sold Today</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* QUICK ACTIONS *@
<section class="kc-section kc-section-mid">
    <div class="container">
        <div class="kc-section-header mb-4">
            <h2 class="kc-section-title fs-4">
                <i class="fa-solid fa-bolt me-2 kc-gold"></i>Quick Actions
            </h2>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <a asp-page="/Movies/Movies" class="kc-action-card text-decoration-none">
                    <div class="kc-action-icon"><i class="fa-solid fa-film"></i></div>
                    <h5 class="kc-action-title">Manage Movies</h5>
                    <p class="kc-action-desc">Add, edit, or remove movies from the schedule.</p>
                    <span class="kc-action-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                </a>
            </div>
            <div class="col-md-6 col-lg-3">
                <a asp-page="/Schedules/Schedules" class="kc-action-card text-decoration-none">
                    <div class="kc-action-icon"><i class="fa-solid fa-calendar-days"></i></div>
                    <h5 class="kc-action-title">Manage Schedules</h5>
                    <p class="kc-action-desc">View and update show times across all screens.</p>
                    <span class="kc-action-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                </a>
            </div>
            <div class="col-md-6 col-lg-3">
                <a asp-page="/Theaters/Theaters" class="kc-action-card text-decoration-none">
                    <div class="kc-action-icon"><i class="fa-solid fa-building"></i></div>
                    <h5 class="kc-action-title">Manage Theaters</h5>
                    <p class="kc-action-desc">Configure screens, seating capacity, and facilities.</p>
                    <span class="kc-action-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                </a>
            </div>
            <div class="col-md-6 col-lg-3">
                <a asp-page="/Reports/Reports" class="kc-action-card text-decoration-none">
                    <div class="kc-action-icon"><i class="fa-solid fa-chart-bar"></i></div>
                    <h5 class="kc-action-title">View Reports</h5>
                    <p class="kc-action-desc">Access ticket sales, occupancy, and performance data.</p>
                    <span class="kc-action-arrow"><i class="fa-solid fa-arrow-right"></i></span>
                </a>
            </div>
        </div>
    </div>
</section>

@* TODAY'S SHOW SCHEDULE *@
<section class="kc-section kc-section-dark">
    <div class="container">
        <div class="kc-section-header d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
            <h2 class="kc-section-title fs-4 mb-0">
                <i class="fa-solid fa-clapperboard me-2 kc-gold"></i>Today's Show Schedule
            </h2>
            <a asp-page="/Schedules/Schedules" class="btn kc-btn-outline btn-sm">
                <i class="fa-solid fa-list me-1"></i>View All Schedules
            </a>
        </div>
        <div class="table-responsive">
            <table class="table kc-table">
                <thead>
                    <tr>
                        <th>Movie</th>
                        <th>Hall</th>
                        <th>Show Time</th>
                        <th>Seats Available</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.TodaysShows.Any())
                    {
                        @foreach (var show in Model.TodaysShows)
                        {
                            <tr>
                                <td><strong class="text-white">@show.MovieTitle</strong></td>
                                <td>@show.HallName</td>
                                <td>@show.ShowTimeStr</td>
                                <td>@show.Available / @show.Capacity</td>
                                <td><span class="kc-status-badge @show.Status.CssClass">@show.Status.Label</span></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-4">No shows scheduled for today.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>