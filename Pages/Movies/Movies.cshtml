@page "/movies"
@model KumariCinemas.Web.Pages.Movies.MoviesModel
@{
    ViewData["Title"] = "Movies";
}

<div class="kc-page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between py-4 flex-wrap gap-3">
            <div>
                <h1 class="kc-dashboard-title mb-1">
                    <i class="fa-solid fa-film me-2 kc-gold"></i>Movies
                </h1>
                <p class="text-secondary mb-0 small">Manage all movies currently in the system.</p>
            </div>
            <button class="btn kc-btn-primary" data-bs-toggle="modal" data-bs-target="#movieModal"
                    onclick="openCreateMovie()">
                <i class="fa-solid fa-plus me-1"></i>Add Movie
            </button>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="container"><div class="alert alert-success alert-dismissible fade show mt-2" role="alert">
        <i class="fa-solid fa-check-circle me-1"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div></div>
}
@if (TempData["Error"] != null)
{
    <div class="container"><div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
        <i class="fa-solid fa-triangle-exclamation me-1"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div></div>
}

<section class="kc-section kc-section-dark" style="padding: 2rem 0 3rem;">
    <div class="container">
        <div class="table-responsive">
            <table class="table kc-table">
                <thead>
                    <tr>
                        <th style="width:4%">ID</th>
                        <th>Title</th>
                        <th>Genre</th>
                        <th>Duration</th>
                        <th>Language</th>
                        <th>Release Date</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Movies.Any())
                    {
                        @foreach (var movie in Model.Movies)
                        {
                            <tr>
                                <td class="text-muted small">@movie.MovieID</td>
                                <td><strong class="text-white">@movie.Title</strong></td>
                                <td>
                                    @foreach (var g in movie.Genre.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="kc-tag">@g</span>
                                    }
                                </td>
                                <td>@movie.Duration min</td>
                                <td>@movie.Language</td>
                                <td>@(movie.ReleaseDate?.ToString("MMM d, yyyy") ?? "—")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm kc-btn-icon" title="Edit" data-bs-toggle="modal"
                                            data-bs-target="#movieModal"
                                            onclick="openEditMovie(@movie.MovieID,'@movie.Title.Replace("'","\\'")','@movie.Genre.Replace("'","\\'")','@movie.Duration','@movie.Language','@(movie.ReleaseDate?.ToString("yyyy-MM-dd") ?? "")')">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <form method="post" asp-page-handler="Delete" class="d-inline"
                                          onsubmit="return confirm('Delete this movie?');">
                                        <input type="hidden" name="DeleteId" value="@movie.MovieID" />
                                        <button type="submit" class="btn btn-sm kc-btn-icon-danger" title="Delete">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="fa-solid fa-film fa-2x mb-2 d-block"></i>
                                No movies found. Click "Add Movie" to create one.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@* ── ADD / EDIT MOVIE MODAL ─────────────────────────────── *@
<div class="modal fade kc-modal" id="movieModal" tabindex="-1" aria-labelledby="movieModalLabel">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title kc-gold" id="movieModalLabel">
                    <i class="fa-solid fa-film me-2"></i><span id="movieModalTitle">Add New Movie</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" id="movieForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="fMovieId" name="MovieInput.MovieID" value="0" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Movie Title</label>
                            <input type="text" class="form-control kc-input" name="MovieInput.Title"
                                   id="fMovieTitle" placeholder="Enter movie title" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Genre</label>
                            <input type="text" class="form-control kc-input" name="MovieInput.Genre"
                                   id="fMovieGenre" placeholder="Action, Drama">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Language</label>
                            <select class="form-select kc-input" name="MovieInput.Language" id="fMovieLang">
                                <option>Nepali</option>
                                <option>English</option>
                                <option>Hindi</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Duration (minutes)</label>
                            <input type="number" class="form-control kc-input" name="MovieInput.Duration"
                                   id="fMovieDuration" placeholder="135" min="1">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Release Date</label>
                            <input type="date" class="form-control kc-input" name="MovieInput.ReleaseDate"
                                   id="fMovieRelease">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn kc-btn-outline btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn kc-btn-primary btn-sm">
                        <i class="fa-solid fa-floppy-disk me-1"></i><span id="movieSaveText">Save Movie</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openCreateMovie() {
        document.getElementById('movieForm').action = '?handler=Create';
        document.getElementById('movieModalTitle').textContent = 'Add New Movie';
        document.getElementById('movieSaveText').textContent = 'Save Movie';
        document.getElementById('fMovieId').value = '0';
        document.getElementById('fMovieTitle').value = '';
        document.getElementById('fMovieGenre').value = '';
        document.getElementById('fMovieDuration').value = '';
        document.getElementById('fMovieLang').value = 'Nepali';
        document.getElementById('fMovieRelease').value = '';
    }
    function openEditMovie(id, title, genre, duration, lang, release) {
        document.getElementById('movieForm').action = '?handler=Update';
        document.getElementById('movieModalTitle').textContent = 'Edit Movie';
        document.getElementById('movieSaveText').textContent = 'Update Movie';
        document.getElementById('fMovieId').value = id;
        document.getElementById('fMovieTitle').value = title;
        document.getElementById('fMovieGenre').value = genre;
        document.getElementById('fMovieDuration').value = duration;
        document.getElementById('fMovieLang').value = lang;
        document.getElementById('fMovieRelease').value = release;
    }
</script>
}
