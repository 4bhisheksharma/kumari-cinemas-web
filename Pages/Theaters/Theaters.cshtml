@page "/theaters"
@model KumariCinemas.Web.Pages.Theaters.TheatersModel
@{
    ViewData["Title"] = "Theaters";
}

<div class="kc-page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between py-4 flex-wrap gap-3">
            <div>
                <h1 class="kc-dashboard-title mb-1">
                    <i class="fa-solid fa-building me-2 kc-gold"></i>Theaters &amp; Halls
                </h1>
                <p class="text-secondary mb-0 small">Manage screens, seating capacity, and hall configurations.</p>
            </div>
            <button class="btn kc-btn-primary" data-bs-toggle="modal" data-bs-target="#theaterModal">
                <i class="fa-solid fa-plus me-1"></i>Add Theater
            </button>
        </div>
    </div>
</div>

<section class="kc-section kc-section-dark" style="padding: 2rem 0 3rem;">
    <div class="container">
        <div class="row g-4">

            <div class="col-md-6 col-lg-4">
                <div class="kc-theater-card">
                    <div class="d-flex align-items-start justify-content-between mb-3">
                        <div>
                            <h5 class="mb-0 text-white">Screen 1</h5>
                            <span class="text-secondary small">Hall A</span>
                        </div>
                        <span class="kc-type-badge kc-type-standard">Standard</span>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div>
                                <div class="kc-theater-stat-val">120</div>
                                <div class="kc-theater-stat-lbl">Total Seats</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div>
                                <div class="kc-theater-stat-val">12 × 10</div>
                                <div class="kc-theater-stat-lbl">Layout (R × C)</div>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex align-items-center justify-content-between pt-2"
                         style="border-top: 1px solid var(--kc-border)">
                        <span class="kc-status-badge kc-status-open">Active</span>
                        <div>
                            <button class="btn btn-sm kc-btn-icon" title="Edit" data-bs-toggle="modal"
                                    data-bs-target="#theaterModal"><i class="fa-solid fa-pen"></i></button>
                            <button class="btn btn-sm kc-btn-icon-danger" title="Delete"><i
                                class="fa-solid fa-trash"></i></button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 col-lg-4">
                    <div class="kc-theater-card">
                        <div class="d-flex align-items-start justify-content-between mb-3">
                            <div>
                                <h5 class="mb-0 text-white">Screen 2</h5>
                                <span class="text-secondary small">Hall B</span>
                            </div>
                            <span class="kc-type-badge kc-type-standard">Standard</span>
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <div>
                                    <div class="kc-theater-stat-val">100</div>
                                    <div class="kc-theater-stat-lbl">Total Seats</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div>
                                    <div class="kc-theater-stat-val">10 × 10</div>
                                    <div class="kc-theater-stat-lbl">Layout (R × C)</div>
                                </div>
                            </div>
                        </div>
                        <div class="d-flex align-items-center justify-content-between pt-2"
                             style="border-top: 1px solid var(--kc-border)">
                            <span class="kc-status-badge kc-status-open">Active</span>
                            <div>
                                <button class="btn btn-sm kc-btn-icon" title="Edit" data-bs-toggle="modal"
                                        data-bs-target="#theaterModal"><i class="fa-solid fa-pen"></i></button>
                                <button class="btn btn-sm kc-btn-icon-danger" title="Delete"><i
                                    class="fa-solid fa-trash"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-4">
                        <div class="kc-theater-card">
                            <div class="d-flex align-items-start justify-content-between mb-3">
                                <div>
                                    <h5 class="mb-0 text-white">Screen 3</h5>
                                    <span class="text-secondary small">Hall C</span>
                                </div>
                                <span class="kc-type-badge kc-type-premium">Premium</span>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <div>
                                        <div class="kc-theater-stat-val">80</div>
                                        <div class="kc-theater-stat-lbl">Total Seats</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div>
                                        <div class="kc-theater-stat-val">8 × 10</div>
                                        <div class="kc-theater-stat-lbl">Layout (R × C)</div>
                                    </div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center justify-content-between pt-2"
                                 style="border-top: 1px solid var(--kc-border)">
                                <span class="kc-status-badge kc-status-open">Active</span>
                                <div>
                                    <button class="btn btn-sm kc-btn-icon" title="Edit" data-bs-toggle="modal"
                                            data-bs-target="#theaterModal"><i class="fa-solid fa-pen"></i></button>
                                    <button class="btn btn-sm kc-btn-icon-danger" title="Delete"><i
                                        class="fa-solid fa-trash"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6 col-lg-4">
                            <div class="kc-theater-card">
                                <div class="d-flex align-items-start justify-content-between mb-3">
                                    <div>
                                        <h5 class="mb-0 text-white">Screen 4</h5>
                                        <span class="text-secondary small">Hall D</span>
                                    </div>
                                    <span class="kc-type-badge kc-type-imax">IMAX</span>
                                </div>
                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <div>
                                            <div class="kc-theater-stat-val">150</div>
                                            <div class="kc-theater-stat-lbl">Total Seats</div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div>
                                            <div class="kc-theater-stat-val">15 × 10</div>
                                            <div class="kc-theater-stat-lbl">Layout (R × C)</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center justify-content-between pt-2"
                                     style="border-top: 1px solid var(--kc-border)">
                                    <span class="kc-status-badge kc-status-open">Active</span>
                                    <div>
                                        <button class="btn btn-sm kc-btn-icon" title="Edit" data-bs-toggle="modal"
                                                data-bs-target="#theaterModal"><i class="fa-solid fa-pen"></i></button>
                                        <button class="btn btn-sm kc-btn-icon-danger" title="Delete"><i
                                            class="fa-solid fa-trash"></i></button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="col-md-6 col-lg-4">
                                <div class="kc-theater-card">
                                    <div class="d-flex align-items-start justify-content-between mb-3">
                                        <div>
                                            <h5 class="mb-0 text-white">Screen 5</h5>
                                            <span class="text-secondary small">Hall E</span>
                                        </div>
                                        <span class="kc-type-badge kc-type-4dx">4DX</span>
                                    </div>
                                    <div class="row g-2 mb-3">
                                        <div class="col-6">
                                            <div>
                                                <div class="kc-theater-stat-val">60</div>
                                                <div class="kc-theater-stat-lbl">Total Seats</div>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div>
                                                <div class="kc-theater-stat-val">6 × 10</div>
                                                <div class="kc-theater-stat-lbl">Layout (R × C)</div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center justify-content-between pt-2"
                                         style="border-top: 1px solid var(--kc-border)">
                                        <span class="kc-status-badge kc-status-maintenance">Maintenance</span>
                                        <div>
                                            <button class="btn btn-sm kc-btn-icon" title="Edit" data-bs-toggle="modal"
                                                    data-bs-target="#theaterModal"><i class="fa-solid fa-pen"></i></button>
                                            <button class="btn btn-sm kc-btn-icon-danger" title="Delete"><i
                                                class="fa-solid fa-trash"></i></button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </section>

                    @* ── ADD / EDIT THEATER MODAL ─────────────────────────────── *@
                    <div class="modal fade kc-modal" id="theaterModal" tabindex="-1" aria-labelledby="theaterModalLabel">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title kc-gold" id="theaterModalLabel">
                                        <i class="fa-solid fa-building me-2"></i>Add New Theater
                                    </h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body p-4">
                                    <form>
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Screen Name</label>
                                                <input type="text" class="form-control kc-input" placeholder="e.g. Screen 6">
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Hall Name</label>
                                                <input type="text" class="form-control kc-input" placeholder="e.g. Hall F">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Type</label>
                                                <select class="form-select kc-input">
                                                    <option>Standard</option>
                                                    <option>Premium</option>
                                                    <option>IMAX</option>
                                                    <option>4DX</option>
                                                </select>
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Rows</label>
                                                <input type="number" class="form-control kc-input" placeholder="10">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Columns</label>
                                                <input type="number" class="form-control kc-input" placeholder="12">
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label">Status</label>
                                                <select class="form-select kc-input">
                                                    <option>Active</option>
                                                    <option>Maintenance</option>
                                                    <option>Inactive</option>
                                                </select>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn kc-btn-outline btn-sm" data-bs-dismiss="modal">Cancel</button>
                                    <button type="button" class="btn kc-btn-primary btn-sm">
                                        <i class="fa-solid fa-floppy-disk me-1"></i>Save Theater
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>