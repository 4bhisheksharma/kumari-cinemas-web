@page "/users"
@model KumariCinemas.Web.Pages.Users.UsersModel
@{
    ViewData["Title"] = "Users";
}

<div class="kc-page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between py-4 flex-wrap gap-3">
            <div>
                <h1 class="kc-dashboard-title mb-1">
                    <i class="fa-solid fa-users me-2 kc-gold"></i>Users
                </h1>
                <p class="text-secondary mb-0 small">Manage staff accounts and contact information.</p>
            </div>
            <button class="btn kc-btn-primary" data-bs-toggle="modal" data-bs-target="#userModal"
                    onclick="openCreateModal()">
                <i class="fa-solid fa-plus me-1"></i>Add User
            </button>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="container">
        <div class="alert alert-success alert-dismissible fade show mt-2" role="alert">
            <i class="fa-solid fa-check-circle me-1"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="container">
        <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-1"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<section class="kc-section kc-section-dark" style="padding: 2rem 0 3rem;">
    <div class="container">
        <div class="table-responsive">
            <table class="table kc-table">
                <thead>
                    <tr>
                        <th style="width:4%">ID</th>
                        <th>Name</th>
                        <th>Contact No.</th>
                        <th>Email</th>
                        <th>Address</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Users.Any())
                    {
                        @foreach (var user in Model.Users)
                        {
                            <tr>
                                <td class="text-muted small">@user.UserID</td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="kc-avatar">@user.UserName[0]</div>
                                        <strong class="text-white">@user.UserName</strong>
                                    </div>
                                </td>
                                <td>@user.ContactNumber</td>
                                <td class="text-secondary">@user.Email</td>
                                <td class="text-secondary">@(user.Address ?? "—")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm kc-btn-icon" title="Edit" data-bs-toggle="modal"
                                            data-bs-target="#userModal"
                                            onclick="openEditModal(@user.UserID, '@user.UserName.Replace("'", "\\'")','@user.ContactNumber','@(user.Email?.Replace("'", "\\'") ?? "")','@(user.Address?.Replace("'", "\\'") ?? "")')">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <form method="post" asp-page-handler="Delete" class="d-inline"
                                          onsubmit="return confirm('Are you sure you want to delete this user?');">
                                        <input type="hidden" name="DeleteId" value="@user.UserID" />
                                        <button type="submit" class="btn btn-sm kc-btn-icon-danger" title="Delete">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fa-solid fa-users-slash fa-2x mb-2 d-block"></i>
                                No users found. Click "Add User" to create one.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@* ── ADD / EDIT USER MODAL ─────────────────────────────── *@
<div class="modal fade kc-modal" id="userModal" tabindex="-1" aria-labelledby="userModalLabel">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title kc-gold" id="userModalLabel">
                    <i class="fa-solid fa-user-plus me-2"></i><span id="modalTitleText">Add New User</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" id="userForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="formUserId" name="UserInput.UserID" value="0" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Full Name</label>
                            <input type="text" class="form-control kc-input" name="UserInput.UserName" id="formUserName"
                                   placeholder="Enter full name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Contact Number</label>
                            <input type="tel" class="form-control kc-input" name="UserInput.ContactNumber"
                                   id="formContact" placeholder="98XXXXXXXX" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control kc-input" name="UserInput.Email" id="formEmail"
                                   placeholder="user@kumaricinemas.com">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Address</label>
                            <input type="text" class="form-control kc-input" name="UserInput.Address" id="formAddress"
                                   placeholder="City / District">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn kc-btn-outline btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn kc-btn-primary btn-sm">
                        <i class="fa-solid fa-floppy-disk me-1"></i><span id="modalSaveText">Save User</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCreateModal() {
            document.getElementById('userForm').action = '?handler=Create';
            document.getElementById('modalTitleText').textContent = 'Add New User';
            document.getElementById('modalSaveText').textContent = 'Save User';
            document.getElementById('formUserId').value = '0';
            document.getElementById('formUserName').value = '';
            document.getElementById('formContact').value = '';
            document.getElementById('formEmail').value = '';
            document.getElementById('formAddress').value = '';
        }
        function openEditModal(id, name, contact, email, address) {
            document.getElementById('userForm').action = '?handler=Update';
            document.getElementById('modalTitleText').textContent = 'Edit User';
            document.getElementById('modalSaveText').textContent = 'Update User';
            document.getElementById('formUserId').value = id;
            document.getElementById('formUserName').value = name;
            document.getElementById('formContact').value = contact;
            document.getElementById('formEmail').value = email;
            document.getElementById('formAddress').value = address;
        }
    </script>
}