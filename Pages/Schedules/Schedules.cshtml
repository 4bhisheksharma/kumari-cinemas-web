@page "/schedules"
@model KumariCinemas.Web.Pages.Schedules.SchedulesModel
@{
    ViewData["Title"] = "Schedules";
}

<div class="kc-page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between py-4 flex-wrap gap-3">
            <div>
                <h1 class="kc-dashboard-title mb-1">
                    <i class="fa-solid fa-calendar-days me-2 kc-gold"></i>Show Schedules
                </h1>
                <p class="text-secondary mb-0 small">View and manage show times across all halls.</p>
            </div>
            <button class="btn kc-btn-primary" data-bs-toggle="modal" data-bs-target="#showModal"
                    onclick="openCreateSchedule()">
                <i class="fa-solid fa-plus me-1"></i>Add Show
            </button>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="container">
        <div class="alert alert-success alert-dismissible fade show mt-2" role="alert">
            <i class="fa-solid fa-check-circle me-1"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="container">
        <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-1"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<section class="kc-section kc-section-dark" style="padding: 2rem 0 3rem;">
    <div class="container">
        <div class="table-responsive">
            <table class="table kc-table">
                <thead>
                    <tr>
                        <th style="width:4%">ID</th>
                        <th>Movie</th>
                        <th>Hall</th>
                        <th>Theatre</th>
                        <th>Date</th>
                        <th>Show Time</th>
                        <th>Start</th>
                        <th>End</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Schedules.Any())
                    {
                        @foreach (var s in Model.Schedules)
                        {
                            <tr>
                                <td class="text-muted small">@s.ShowID</td>
                                <td><strong class="text-white">@s.MovieTitle</strong></td>
                                <td>@s.HallName</td>
                                <td class="text-secondary">@s.TheatreName</td>
                                <td>@s.ShowDate.ToString("MMM d, yyyy")</td>
                                <td>@s.ShowTime.ToString("h:mm tt")</td>
                                <td>@(s.StartTime?.ToString("h:mm tt") ?? "—")</td>
                                <td>@(s.EndTime?.ToString("h:mm tt") ?? "—")</td>
                                <td class="text-end">
                                    <button class="btn btn-sm kc-btn-icon" title="Edit" data-bs-toggle="modal"
                                            data-bs-target="#showModal"
                                            onclick="openEditSchedule(@s.ShowID, @s.MovieID, @s.HallID, '@s.ShowDate.ToString("yyyy-MM-dd")', '@s.ShowTime.ToString("yyyy-MM-ddTHH:mm")', '@(s.StartTime?.ToString("yyyy-MM-ddTHH:mm") ?? "")', '@(s.EndTime?.ToString("yyyy-MM-ddTHH:mm") ?? "")')">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <form method="post" asp-page-handler="Delete" class="d-inline"
                                          onsubmit="return confirm('Delete this show?');">
                                        <input type="hidden" name="DeleteId" value="@s.ShowID" />
                                        <button type="submit" class="btn btn-sm kc-btn-icon-danger" title="Delete">
                                            <i class="fa-solid fa-ban"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="fa-solid fa-calendar-xmark fa-2x mb-2 d-block"></i>
                                No shows found. Click "Add Show" to create one.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@* ── ADD / EDIT SHOW MODAL ─────────────────────────────── *@
<div class="modal fade kc-modal" id="showModal" tabindex="-1" aria-labelledby="showModalLabel">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title kc-gold" id="showModalLabel">
                    <i class="fa-solid fa-clapperboard me-2"></i><span id="scheduleModalTitle">Add New Show</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" id="scheduleForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="fShowId" name="ScheduleInput.ShowID" value="0" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Movie</label>
                            <select class="form-select kc-input" name="ScheduleInput.MovieID" id="fSchMovie" required>
                                <option value="">-- Select Movie --</option>
                                @foreach (var m in Model.MovieOptions)
                                {
                                    <option value="@m.Value">@m.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Hall</label>
                            <select class="form-select kc-input" name="ScheduleInput.HallID" id="fSchHall" required>
                                <option value="">-- Select Hall --</option>
                                @foreach (var h in Model.HallOptions)
                                {
                                    <option value="@h.Value">@h.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Show Date</label>
                            <input type="date" class="form-control kc-input" name="ScheduleInput.ShowDate"
                                   id="fSchDate" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Show Time</label>
                            <input type="datetime-local" class="form-control kc-input" name="ScheduleInput.ShowTime"
                                   id="fSchShowTime" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Start Time</label>
                            <input type="datetime-local" class="form-control kc-input" name="ScheduleInput.StartTime"
                                   id="fSchStart">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">End Time</label>
                            <input type="datetime-local" class="form-control kc-input" name="ScheduleInput.EndTime"
                                   id="fSchEnd">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn kc-btn-outline btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn kc-btn-primary btn-sm">
                        <i class="fa-solid fa-floppy-disk me-1"></i><span id="scheduleSaveText">Save Show</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCreateSchedule() {
            document.getElementById('scheduleForm').action = '?handler=Create';
            document.getElementById('scheduleModalTitle').textContent = 'Add New Show';
            document.getElementById('scheduleSaveText').textContent = 'Save Show';
            document.getElementById('fShowId').value = '0';
            document.getElementById('fSchMovie').value = '';
            document.getElementById('fSchHall').value = '';
            document.getElementById('fSchDate').value = '';
            document.getElementById('fSchShowTime').value = '';
            document.getElementById('fSchStart').value = '';
            document.getElementById('fSchEnd').value = '';
        }
        function openEditSchedule(id, movieId, hallId, date, showTime, start, end) {
            document.getElementById('scheduleForm').action = '?handler=Update';
            document.getElementById('scheduleModalTitle').textContent = 'Edit Show';
            document.getElementById('scheduleSaveText').textContent = 'Update Show';
            document.getElementById('fShowId').value = id;
            document.getElementById('fSchMovie').value = movieId;
            document.getElementById('fSchHall').value = hallId;
            document.getElementById('fSchDate').value = date;
            document.getElementById('fSchShowTime').value = showTime;
            document.getElementById('fSchStart').value = start;
            document.getElementById('fSchEnd').value = end;
        }
    </script>
}