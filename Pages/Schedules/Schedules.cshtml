                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h5 class="modal-title kc-gold" id="showModalLabel">
                                                    <i class="fa-solid fa-clapperboard me-2"></i>Add New Show
                                                </h5>
                                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                            </div>
                                            <div class="modal-body p-4">
                                                <form>
                                                    <div class="row g-3">
                                                        <div class="col-12">
                                                            <label class="form-label">Movie</label>
                                                            <select class="form-select kc-input">
                                                                <option value="">Select a movie...</option>
                                                                <option>Everest's Call</option>
                                                                <option>Shadow Realm</option>
                                                                <option>Kathmandu Nights</option>
                                                                <option>Star Odyssey</option>
                                                            </select>
                                                        </div>
                                                        <div class="col-12">
                                                            <label class="form-label">Screen</label>
                                                            <select class="form-select kc-input">
                                                                <option value="">Select a screen...</option>
                                                                <option>Screen 1 (Hall A) — Standard, 120 seats</option>
                                                                <option>Screen 2 (Hall B) — Standard, 100 seats</option>
                                                                <option>Screen 3 (Hall C) — Premium, 80 seats</option>
                                                                <option>Screen 4 (Hall D) — IMAX, 150 seats</option>
                                                            </select>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label">Show Date</label>
                                                            <input type="date" class="form-control kc-input">
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label">Start Time</label>
                                                            <input type="time" class="form-control kc-input">
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label">Ticket Price (Rs.)</label>
                                                            <input type="number" class="form-control kc-input" placeholder="300">
                                                        </div>
                                                        <div class="col-md-6">
                                                            <label class="form-label">Status</label>
                                                            <select class="form-select kc-input">
                                                                <option>Scheduled</option>
                                                                <option>Cancelled</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                </form>
