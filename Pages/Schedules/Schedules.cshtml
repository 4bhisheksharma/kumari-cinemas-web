                    <button type="button" class="btn kc-btn-primary">Today</button>
                    <button type="button" class="btn kc-btn-outline">Tomorrow</button>
                    <button type="button" class="btn kc-btn-outline">This Week</button>
                </div>
            </div>
            <div class="col-auto">
                <select class="form-select form-select-sm kc-input">
                    <option value="">All Movies</option>
                    <option>Everest's Call</option>
                    <option>Shadow Realm</option>
                    <option>Kathmandu Nights</option>
                    <option>Star Odyssey</option>
                </select>
            </div>
            <div class="col-auto">
                <select class="form-select form-select-sm kc-input">
                    <option value="">All Screens</option>
                    <option>Screen 1 (Hall A)</option>
                    <option>Screen 2 (Hall B)</option>
                    <option>Screen 3 (Hall C)</option>
                    <option>Screen 4 (Hall D)</option>
                </select>
            </div>
            <div class="col-auto ms-auto">
                <input type="date" class="form-control form-control-sm kc-input" value="2026-03-04">
            </div>
        </div>
    </div>
</div>

