@page "/tickets"
@model KumariCinemas.Web.Pages.Tickets.TicketsModel
@{
    ViewData["Title"] = "Tickets";
}

<div class="kc-page-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between py-4 flex-wrap gap-3">
            <div>
                <h1 class="kc-dashboard-title mb-1">
                    <i class="fa-solid fa-ticket me-2 kc-gold"></i>Ticket Oversight
                </h1>
                <p class="text-secondary mb-0 small">View and manage all ticket bookings across shows.</p>
            </div>
            <button class="btn kc-btn-primary" data-bs-toggle="modal" data-bs-target="#ticketModal"
                    onclick="openCreateTicket()">
                <i class="fa-solid fa-plus me-1"></i>Add Ticket
            </button>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="container">
        <div class="alert alert-success alert-dismissible fade show mt-2" role="alert">
            <i class="fa-solid fa-check-circle me-1"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="container">
        <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-1"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<section class="kc-section kc-section-dark" style="padding: 2rem 0 3rem;">
    <div class="container">
        <div class="table-responsive">
            <table class="table kc-table">
                <thead>
                    <tr>
                        <th>Ticket #</th>
                        <th>Confirmation</th>
                        <th>User</th>
                        <th>Movie</th>
                        <th>Hall</th>
                        <th>Seat</th>
                        <th>Date</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Tickets.Any())
                    {
                        @foreach (var t in Model.Tickets)
                        {
                            var tStatusClass = t.TicketStatus switch
                            {
                                "Cancelled" => "kc-status-cancelled",
                                "Paid" => "kc-status-open",
                                _ => "kc-status-filling"
                            };
                            <tr>
                                <td class="kc-gold small fw-bold">@t.TicketNumber</td>
                                <td class="text-secondary small">@t.ConfirmationNumber</td>
                                <td>@t.UserName</td>
                                <td><strong class="text-white">@t.MovieTitle</strong></td>
                                <td>@t.HallName</td>
                                <td><span class="kc-tag">@t.SeatRow@t.SeatNumber</span></td>
                                <td>@(t.ShowDate == DateTime.MinValue ? "—" : t.ShowDate.ToString("MMM d, yyyy"))</td>
                                <td>Rs. @t.Amount.ToString("N0")</td>
                                <td><span class="kc-status-badge @tStatusClass">@t.TicketStatus</span></td>
                                <td class="text-end">
                                    <button class="btn btn-sm kc-btn-icon" title="Edit" data-bs-toggle="modal"
                                            data-bs-target="#ticketModal"
                                            onclick="openEditTicket(@t.TicketID, @t.BookingID, @t.SeatID, @t.PriceID, '@t.TicketNumber', '@t.TicketStatus')">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <form method="post" asp-page-handler="Delete" class="d-inline"
                                          onsubmit="return confirm('Delete this ticket?');">
                                        <input type="hidden" name="DeleteId" value="@t.TicketID" />
                                        <button type="submit" class="btn btn-sm kc-btn-icon-danger" title="Delete">
                                            <i class="fa-solid fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" class="text-center text-muted py-4">
                                <i class="fa-solid fa-ticket fa-2x mb-2 d-block"></i>
                                No tickets found. Click "Add Ticket" to create one.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@* ── ADD / EDIT TICKET MODAL ─────────────────────────────── *@
<div class="modal fade kc-modal" id="ticketModal" tabindex="-1" aria-labelledby="ticketModalLabel">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title kc-gold" id="ticketModalLabel">
                    <i class="fa-solid fa-ticket me-2"></i><span id="ticketModalTitle">Add New Ticket</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" id="ticketForm">
                <div class="modal-body p-4">
                    <input type="hidden" id="fTicketId" name="TicketInput.TicketID" value="0" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Booking</label>
                            <select class="form-select kc-input" name="TicketInput.BookingID" id="fTktBooking" required>
                                <option value="">-- Select Booking --</option>
                                @foreach (var b in Model.BookingOptions)
                                {
                                    <option value="@b.Value">@b.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Seat</label>
                            <select class="form-select kc-input" name="TicketInput.SeatID" id="fTktSeat" required>
                                <option value="">-- Select Seat --</option>
                                @foreach (var s in Model.SeatOptions)
                                {
                                    <option value="@s.Value">@s.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Pricing</label>
                            <select class="form-select kc-input" name="TicketInput.PriceID" id="fTktPrice" required>
                                <option value="">-- Select Price --</option>
                                @foreach (var p in Model.PricingOptions)
                                {
                                    <option value="@p.Value">@p.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Ticket Number</label>
                            <input type="text" class="form-control kc-input" name="TicketInput.TicketNumber"
                                   id="fTktNumber" placeholder="TKT-001" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Status</label>
                            <select class="form-select kc-input" name="TicketInput.TicketStatus" id="fTktStatus">
                                <option>Booked</option>
                                <option>Cancelled</option>
                                <option>Paid</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn kc-btn-outline btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn kc-btn-primary btn-sm">
                        <i class="fa-solid fa-floppy-disk me-1"></i><span id="ticketSaveText">Save Ticket</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openCreateTicket() {
            document.getElementById('ticketForm').action = '?handler=Create';
            document.getElementById('ticketModalTitle').textContent = 'Add New Ticket';
            document.getElementById('ticketSaveText').textContent = 'Save Ticket';
            document.getElementById('fTicketId').value = '0';
            document.getElementById('fTktBooking').value = '';
            document.getElementById('fTktSeat').value = '';
            document.getElementById('fTktPrice').value = '';
            document.getElementById('fTktNumber').value = '';
            document.getElementById('fTktStatus').value = 'Booked';
        }
        function openEditTicket(id, bookingId, seatId, priceId, ticketNum, status) {
            document.getElementById('ticketForm').action = '?handler=Update';
            document.getElementById('ticketModalTitle').textContent = 'Edit Ticket';
            document.getElementById('ticketSaveText').textContent = 'Update Ticket';
            document.getElementById('fTicketId').value = id;
            document.getElementById('fTktBooking').value = bookingId;
            document.getElementById('fTktSeat').value = seatId;
            document.getElementById('fTktPrice').value = priceId;
            document.getElementById('fTktNumber').value = ticketNum;
            document.getElementById('fTktStatus').value = status;
        }
    </script>
}